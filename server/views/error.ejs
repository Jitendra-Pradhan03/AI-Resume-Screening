<!DOCTYPE html>
<!--
  server/views/error.ejs
  Why this file exists: Without this, any Express error that happens during
  page rendering shows a raw JSON response or a stack trace in the browser.
  This renders a clean, consistent error page instead.
  How it connects: Used by a dedicated error-page handler added to app.js
  that intercepts errors on page routes (not /api routes — those still
  return JSON via errorHandler.js).
-->
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .error-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: var(--space-6); }
    .error-card { text-align: center; max-width: 480px; }
    .error-code { font-size: 5rem; font-weight: var(--font-weight-bold); color: var(--color-primary); line-height: 1; margin-bottom: var(--space-4); }
    .error-actions { margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; }
  </style>
</head>
<body>
  <div class="error-page">
    <div class="error-card">
      <div class="error-code"><%= status || 500 %></div>
      <h2><%= message || "Something went wrong" %></h2>
      <p class="text-secondary" style="margin-top: var(--space-3);">
        The page you were looking for could not be loaded.
      </p>
      <div class="error-actions">
        <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
        <a href="javascript:history.back()" class="btn btn-secondary">Go back</a>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>