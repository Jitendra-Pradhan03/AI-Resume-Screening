<!-- server/views/partials/footer.ejs
     Why this partial exists: All pages need api.js, auth.js, and ui.js
     loaded before their own page scripts. Loading them in a shared footer
     partial means they're always present in the right order.
     How it connects: Included just before </body> in every layout.
     Key concept: Scripts go at the bottom so the DOM is ready before JS runs.
     We use type="text/javascript" explicitly for clarity. -->

<script src="/js/api.js"></script>
<script src="/js/auth.js"></script>
<script src="/js/ui.js"></script>

<!-- sidebar.js only needed on authenticated (app shell) pages -->
<% if (locals.includesSidebar) { %>
  <script src="/js/sidebar.js"></script>
<% } %>